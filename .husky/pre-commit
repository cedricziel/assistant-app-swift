#!/usr/bin/env bash

set -euo pipefail

has_cmd() {
    command -v "$1" >/dev/null 2>&1
}

run_prettier() {
    local mode="$1"
    local file="$2"

    if has_cmd bunx; then
        bunx prettier "$mode" "$file"
    elif has_cmd npx; then
        npx prettier "$mode" "$file"
    elif has_cmd prettier; then
        prettier "$mode" "$file"
    else
        echo "pre-commit: prettier is required for Markdown checks"
        echo "Install one of: bun (bunx), Node.js (npx), or prettier globally"
        exit 1
    fi
}

if ! has_cmd git; then
    echo "pre-commit: git command not found"
    exit 1
fi

swift_files=()
markdown_files=()

while IFS= read -r -d '' file; do
    case "$file" in
        *.swift)
            swift_files+=("$file")
            ;;
        *.md|*.mdx|*.markdown)
            markdown_files+=("$file")
            ;;
    esac
done < <(git diff --cached --name-only --diff-filter=ACMR -z)

if [[ ${#swift_files[@]} -eq 0 && ${#markdown_files[@]} -eq 0 ]]; then
    exit 0
fi

if [[ ${#swift_files[@]} -gt 0 ]]; then
    if ! has_cmd swiftformat; then
        echo "pre-commit: swiftformat is required when committing .swift files"
        echo "Install with: brew install swiftformat"
        exit 1
    fi

    for file in "${swift_files[@]}"; do
        swiftformat "$file"
    done

    git add -- "${swift_files[@]}"

    for file in "${swift_files[@]}"; do
        swiftformat --lint "$file"
    done
fi

if [[ ${#markdown_files[@]} -gt 0 ]]; then
    for file in "${markdown_files[@]}"; do
        run_prettier --write "$file"
    done

    git add -- "${markdown_files[@]}"

    for file in "${markdown_files[@]}"; do
        run_prettier --check "$file"
    done
fi
